# Base model to fine-tune. Ensure you have this model pulled:
# ollama pull mannix/defog-llama3-sqlcoder-8b
FROM mannix/defog-llama3-sqlcoder-8b

# --- Training Parameters (Adjust as needed) ---
PARAMETER num_train_epochs 3
PARAMETER learning_rate 2e-5
PARAMETER batch_size 4
PARAMETER max_seq_len 8192
PARAMETER warmup_ratio 0.03
PARAMETER weight_decay 0.01

# Optional: Add a system prompt
SYSTEM """You are an expert PostgreSQL SQL query generator."""
